# Email Engine Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# SECURITY - REQUIRED
# =============================================================================

# AES encryption key for credential storage (32 bytes, base64 encoded)
# Generate with: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
AES_SECRET_KEY=your_32_byte_base64_encoded_key_here

# JWT signing key for authentication tokens
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your_jwt_secret_key_here

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

APP_NAME=ConnexxionEngine
DEBUG=false

# =============================================================================
# EMAIL PROTOCOL SETTINGS
# =============================================================================

# SMTP Configuration
SMTP_USE_SSL=true
SMTP_TIMEOUT_SECONDS=30

# IMAP Configuration  
IMAP_USE_SSL=true
IMAP_TIMEOUT_SECONDS=30

# =============================================================================
# CONNECTION POOLING - NEW FEATURES
# =============================================================================

# Maximum number of connections per user in the pool
MAX_CONNECTIONS=50

# Maximum idle time before connection cleanup (seconds)
MAX_IDLE_TIME=300

# How often to run connection cleanup (seconds)
CONNECTION_CLEANUP_INTERVAL=60


# =============================================================================
# CORS SETTINGS
# =============================================================================

# Comma-separated list of allowed origins
# Example: http://localhost:3000,http://localhost:5173,https://yourapp.com
CORS_ORIGINS=

# =============================================================================
# EXAMPLE CONFIGURATIONS FOR DIFFERENT ENVIRONMENTS
# =============================================================================

# Development Environment:
# DEBUG=true
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Copy to .env and adjust values
APP_NAME=Email Engine
DEBUG=false

# Security: base64-encoded 32-byte key (e.g., from Python: base64.b64encode(os.urandom(32)).decode())
AES_SECRET_KEY=

JWT_SECRET_KEY=
JWT_ALGORITHM=HS256 
JWT_EXPIRES_MINUTES=60
# SMTP/IMAP
SMTP_USE_SSL=true
IMAP_USE_SSL=true
SMTP_TIMEOUT_SECONDS=15
IMAP_TIMEOUT_SECONDS=15

